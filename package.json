{
  "name": "@erag/inertia-calendar-vue",
  "version": "0.1.0",
  "description": "Inertia Vue calendar components using the Erag calendar UI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "dist/style.css",
    "src/styles.css"
  ],
  "main": "dist/inertia-calendar.umd.cjs",
  "module": "dist/inertia-calendar.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/inertia-calendar.js",
      "require": "./dist/inertia-calendar.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "eslint": "ESLINT_USE_FLAT_CONFIG=false eslint --resolve-plugins-relative-to . \"src/**/*.{ts,tsx,vue}\"",
    "lint": "prettier --write \"src/**/*.{ts,tsx,js,json,md,vue}\"",
    "lint:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md,vue}\"",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@inertiajs/vue3": "^3.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@inertiajs/vue3": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.1.0"
  }
}
